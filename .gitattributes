# Auto-normalize line endings
* text=auto

# Force LF for shell scripts and M routines (Unix execution targets)
*.sh text eol=lf
*.m text eol=lf

# Force CRLF for Windows scripts
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
