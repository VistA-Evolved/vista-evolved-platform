# Control-plane admin API — environment variables
# Copy to .env and fill in real values.

# PostgreSQL connection (match docker-compose.yml: port 5433, user cp_admin)
CONTROL_PLANE_PG_URL=postgresql://cp_admin:cp_admin_dev@127.0.0.1:5433/control_plane

# Server
PORT=4510
HOST=127.0.0.1

# Lago billing engine (self-hosted)
# The API key is set via LAGO_ORG_API_KEY in services/lago/docker-compose.yml
# Default dev key: ve-lago-api-key-change-in-production
# PRODUCTION: Generate with: openssl rand -hex 32
LAGO_API_URL=http://127.0.0.1:3040/api/v1
LAGO_API_KEY=ve-lago-api-key-change-in-production

# Lago webhook signature secret (optional, for receiving Lago webhooks)
# LAGO_WEBHOOK_SECRET=your-webhook-secret-here
