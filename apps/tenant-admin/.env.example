# Tenant Admin — Environment Configuration
#
# VistA direct broker connection (required for live data)
# Without credentials, the app falls back to fixture data with honest labeling.
VISTA_HOST=127.0.0.1
VISTA_PORT=9434
VISTA_ACCESS_CODE=PRO1234
VISTA_VERIFY_CODE=PRO1234!!
VISTA_CONTEXT=OR CPRS GUI CHART

# Optional: enable XWB protocol debug logging
# VISTA_DEBUG=true

# Broker read timeout (default: 10000ms)
# VISTA_TIMEOUT_MS=10000

# Server port (default: 4520)
# PORT=4520
