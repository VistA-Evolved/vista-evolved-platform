# VistA Evolved Web Frontend — Environment Configuration
# Copy this file to .env and update values for your environment.

# Tenant Admin API (VistA XWB/DDR backend)
VITE_TENANT_API_BASE=/api/ta/v1

# Control Plane API (Postgres backend)  
VITE_OPERATOR_API_BASE=/api/op/v1

# Dev server port
VITE_PORT=3000
