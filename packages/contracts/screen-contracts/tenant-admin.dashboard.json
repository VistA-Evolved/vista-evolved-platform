{
  "surfaceId": "tenant-admin.dashboard",
  "version": "0.1.0",
  "title": "Tenant Dashboard",
  "status": "draft",
  "description": "Tenant-scoped summary dashboard. Displays user count, facility count, module status, and VistA grounding posture. Entry point after cross-workspace transition from operator console. No VistA equivalent — aggregates platform PG tenant state.",
  "workspaceFamily": "tenant-admin",
  "navigationLevel": "primary",
  "surfaceType": "admin",
  "accessRequirements": {
    "allowedRoles": ["tenant-admin"],
    "scopePosture": "tenant-scoped",
    "entityContextRequired": ["tenantId"]
  },
  "readWritePosture": "read-only",
  "directWriteAllowed": false,
  "dataSources": [
    {
      "sourceId": "platform-tenant-registry",
      "sourceDomainClass": "platform-governance",
      "description": "Tenant identity, lifecycle status, configuration summary."
    },
    {
      "sourceId": "platform-user-registry",
      "sourceDomainClass": "platform-governance",
      "description": "User count and role distribution for this tenant."
    },
    {
      "sourceId": "platform-facility-registry",
      "sourceDomainClass": "platform-governance",
      "description": "Facility count and hierarchy summary for this tenant."
    }
  ],
  "dataClassification": "configuration",
  "claimSurface": null,
  "analyticsSurface": null,
  "crossWorkspaceTransitions": [
    {
      "direction": "incoming",
      "targetWorkspaceFamily": "control-plane",
      "targetSurfaceId": "control-plane.tenants.detail",
      "contextParameters": ["tenantId", "operatorId"],
      "accessReEvaluation": true
    }
  ],
  "readinessDependencies": [],
  "refreshBehavior": "on-demand"
}
