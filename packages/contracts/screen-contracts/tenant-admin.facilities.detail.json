{
  "surfaceId": "tenant-admin.facilities.detail",
  "version": "0.2.0",
  "title": "Facility Detail",
  "status": "draft",
  "description": "Detail view for a single facility within a tenant. Displays institution identity (File 4), division (File 40.8), child locations (File 44 clinics, File 42 wards with bed inventory), and VistA grounding status. Enhanced with station number, facility type, global references, and file field mappings.",
  "vistaFields": {
    "File 4": ["NAME (.01)", "STATION NUMBER (99)", "FACILITY TYPE (13)"],
    "File 40.8": ["NAME (.01)", "FACILITY NUMBER (.07)", "INSTITUTION (.01)"],
    "File 44": ["NAME (.01)", "ABBREVIATION (.01,2)", "TYPE (.01,3)", "STOP CODE NUMBER (8)", "DEFAULT SLOT LENGTH (1912)"],
    "File 42": ["NAME (.01)", "SPECIALTY (2)"]
  },
  "rpcs": ["XUS DIVISION GET", "DDR GETS ENTRY DATA", "ORWU CLINLOC", "ORQPT WARDS"],
  "workspaceFamily": "tenant-admin",
  "navigationLevel": "local",
  "surfaceType": "admin",
  "accessRequirements": {
    "allowedRoles": ["tenant-admin"],
    "scopePosture": "tenant-scoped",
    "entityContextRequired": ["tenantId", "facilityId"]
  },
  "readWritePosture": "read-only",
  "directWriteAllowed": false,
  "dataSources": [
    {
      "sourceId": "vista-file-4",
      "sourceDomainClass": "vista-operational-truth",
      "description": "VistA institution record from File 4 — name, type, parent, status."
    },
    {
      "sourceId": "vista-file-44",
      "sourceDomainClass": "vista-operational-truth",
      "description": "VistA hospital location records from File 44 — child clinics, wards, rooms. RPCs: ORWU CLINLOC, ORWU HOSPLOC."
    },
    {
      "sourceId": "platform-tenant-facility-mapping",
      "sourceDomainClass": "platform-governance",
      "description": "Platform tenant-to-facility association and configuration."
    }
  ],
  "dataClassification": "configuration",
  "claimSurface": null,
  "analyticsSurface": null,
  "crossWorkspaceTransitions": [],
  "readinessDependencies": [],
  "refreshBehavior": "on-demand"
}
